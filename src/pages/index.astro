---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR_EMAIL, SECTIONS, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				margin-bottom: 1.5rem;
			}
			.hero img {
				border-radius: 50%;
				width: 120px;
				height: 120px;
				object-fit: cover;
				flex-shrink: 0;
			}
			.hero h1 {
				margin: 0;
			}
			.sections {
				list-style: none;
				padding: 0;
				margin: 2rem 0 0;
			}
			.sections li {
				margin-bottom: 1rem;
			}
			.sections a {
				font-weight: 700;
			}
			.sections p {
				margin: 0.15rem 0 0;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.hero {
					flex-direction: column;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<Image src={profileImage} alt="Sunil Mayya" width={240} height={240} />
				<h1>Sunil Mayya: browser plumber, home cook, dad of two 🦊</h1>
			</div>
			<p>
				I'm a software engineer at Mozilla working on Firefox, mostly the
				web platform and networking, based in Nuremberg, Germany. Day to day
				that means implementing web-platform features in Gecko and taking part in
				the standards conversations (WICG, IETF, W3C) that shape them.
			</p>
			<p>
				A lot of my recent work sits at the boundary between the browser and the
				network:{' '}
				<a href="https://wicg.github.io/local-network-access/">Local Network Access</a>,{' '}
				<a href="https://wicg.github.io/nav-speculation/speculation-rules.html">Speculation Rules</a>,{' '}
				HTTP <a href="https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Headers/No-Vary-Search">No-Vary-Search</a>,{' '}
				the <a href="https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API">Fetch API</a>{' '}
				(including <a href="https://developer.mozilla.org/en-US/docs/Web/API/RequestInit#keepalive">keepalive</a>),{' '}
				and <a href="https://developer.mozilla.org/en-US/docs/Web/API/WebTransport">WebTransport</a>.{' '}
				I enjoy the parts of the job that don't make it into the release notes:
				the design tradeoffs, the cross-vendor disagreements, and the
				implementation details you only discover once you try to ship the thing.
			</p>
			<p>
				This site is a bit of a mix: browser engineering, cooking, and notes on
				life. Read a bit more <a href="/about/">about me</a>, or say hello at{' '}
				<a href={`mailto:${AUTHOR_EMAIL}`}>{AUTHOR_EMAIL}</a>.
			</p>

			<ul class="sections">
				{
					SECTIONS.map((section) => (
						<li>
							<a href={`/${section.slug}`}>{section.title}</a>
							<p>{section.description}</p>
						</li>
					))
				}
				<li>
					<a href="/reading">Reading</a>
					<p>What's on my nightstand right now.</p>
				</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
